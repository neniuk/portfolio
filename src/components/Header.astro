---
import Date from "./Date.svelte";
import DarkmodeToggle from "./DarkmodeToggle.svelte";
---

<header class="w-full">
	<div class="w-full bg-black dark:bg-white px-4 py-2">
		<div
			class="flex flex-row items-center justify-between max-w-4xl mx-auto"
		>
			<p class="text-md text-white dark:text-black">
				<Date client:load />
			</p>

			<div class="flex flex-row items-center justify-center gap-4">
				<DarkmodeToggle client:load />
				<h1 class="text-md">
					<a href="/" class="text-white dark:text-black">
						{Astro.props.title}
					</a>
				</h1>
			</div>
		</div>
	</div>
	<div class="flex flex-row items-start justify-start max-w-4xl mx-auto">
		<div class="mt-16">
			<div
				class="inline-flex flex-col border-l-4 pl-4 border-black/20 dark:border-white/20"
			>
				<h1 class="text-5xl font-black ...">Mattias Slotte</h1>
				<p class="text-xl ...">Software Engineer, Finland</p>
			</div>
		</div>
	</div>
</header>
