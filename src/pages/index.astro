---
import Layout from "../layouts/Layout.astro";
import { siGithub } from "simple-icons";
import RotatingHeadlines from "../components/RotatingHeadlines.svelte";

const featuredProjects = [
	{
		title: "Gameboy Emulator",
		description:
			"C++ emulator for early DMG cartridges, built to explore low-level systems work and hardware behavior.",
		stack: "C++ · Emulation · Systems",
		link: "https://github.com/neniuk/gbemu",
	},
	{
		title: "Hackathon Project",
		description:
			"Multi-agent scheduling platform for wastewater pumping stations, combining a digital twin, OPC-UA server, and an MCP server.",
		stack: "Python · TypeScript · React",
		link: "https://github.com/alexha11/Junction-2025",
	},
	{
		title: "Playlist Downloader",
		description: "CLI tool for fetching playlists and tracks from Spotify.",
		stack: "Python · API Design · CLI",
		link: "https://github.com/neniuk/download-playlist",
	},
];

const experience = [
	{
		role: "Cloud Software Trainee",
		period: "Feb 2025 — Aug 2025 & May 2024 — Aug 2024",
		description:
			"Developed and maintained both backend services and frontend components in an agile software development team.",
		stack: "TypeScript · Node.js · AWS · Angular",
	},
	{
		role: "Database Design Intern",
		period: "Apr 2023 — Aug 2023",
		description:
			"Design, development, testing, and implementation of an internal system and its database.",
		stack: "SQL · VBA · Python",
	},
];
---

<Layout title="Mattias Slotte | Portfolio">
	<section
		class="grid gap-10 pb-10 lg:grid-cols-[1.35fr_0.9fr] lg:items-start"
	>
		<div class="space-y-8">
			<div class="space-y-5">
				<RotatingHeadlines
					client:load
					items={[
						"Connecting services, data, and product surfaces.",
						"Backend-leaning fullstack developer.",
						"Building products and systems.",
					]}
					intervalMs={6000}
				/>
				<p
					class="max-w-2xl text-lg leading-8 text-gray-700 dark:text-gray-300"
				>
					I'm Mattias, a master's student in computer science at Aalto
					University in Finland, focused on fullstack & backend
					development with a growing interest in computer graphics.
				</p>
			</div>

			<div class="flex flex-wrap gap-3">
				<a
					href="https://github.com/neniuk"
					target="_blank"
					class="flex flex-row items-center justify-center gap-2 rounded-full border-2 border-black/15 px-5 py-3 text-sm font-semibold text-black transition hover:-translate-y-0.5 hover:border-black/40 dark:border-white/20 dark:text-white dark:hover:border-white/50"
				>
					<svg
						viewBox="0 0 24 24"
						width="24"
						height="24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path d={siGithub.path}></path>
					</svg>
					GitHub
				</a>
				<a
					href="https://www.linkedin.com/in/mattiasvslotte/"
					target="_blank"
					class="flex flex-row items-center justify-center gap-2 rounded-full border-2 border-black/15 px-5 py-3 text-sm font-semibold text-black transition hover:-translate-y-0.5 hover:border-black/40 dark:border-white/20 dark:text-white dark:hover:border-white/50"
				>
					<svg
						viewBox="0 0 32 32"
						width="24"
						height="24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path
							d="M28.778 1.004h-25.56c-0.008-0-0.017-0-0.027-0-1.199 0-2.172 0.964-2.186 2.159v25.672c0.014 1.196 0.987 2.161 2.186 2.161 0.010 0 0.019-0 0.029-0h25.555c0.008 0 0.018 0 0.028 0 1.2 0 2.175-0.963 2.194-2.159l0-0.002v-25.67c-0.019-1.197-0.994-2.161-2.195-2.161-0.010 0-0.019 0-0.029 0h0.001zM9.9 26.562h-4.454v-14.311h4.454zM7.674 10.293c-1.425 0-2.579-1.155-2.579-2.579s1.155-2.579 2.579-2.579c1.424 0 2.579 1.154 2.579 2.578v0c0 0.001 0 0.002 0 0.004 0 1.423-1.154 2.577-2.577 2.577-0.001 0-0.002 0-0.003 0h0zM26.556 26.562h-4.441v-6.959c0-1.66-0.034-3.795-2.314-3.795-2.316 0-2.669 1.806-2.669 3.673v7.082h-4.441v-14.311h4.266v1.951h0.058c0.828-1.395 2.326-2.315 4.039-2.315 0.061 0 0.121 0.001 0.181 0.003l-0.009-0c4.5 0 5.332 2.962 5.332 6.817v7.855z"
						></path>
					</svg>
					LinkedIn
				</a>
			</div>
		</div>
	</section>

	<section class="border-t border-black/10 py-10 dark:border-white/10">
		<div class="flex items-end justify-between gap-4">
			<div>
				<p
					class="text-sm font-semibold uppercase tracking-[0.3em] text-gray-500 dark:text-gray-400"
				>
					Latest Projects
				</p>
				<h2
					class="mt-2 text-3xl font-black tracking-tight text-black dark:text-white sm:text-4xl"
				>
					Some things I've built.
				</h2>
			</div>
		</div>

		<div class="mt-6 grid gap-5 lg:grid-cols-3">
			{
				featuredProjects.map((project) => (
					<article class="group flex flex-col pb-16 relative rounded-[1.75rem] border-2 border-black/10 bg-black/2 p-6 dark:border-white/10 dark:bg-white/5">
						<p class="text-xs font-semibold uppercase tracking-[0.3em] text-gray-500 dark:text-gray-400">
							Featured Project
						</p>
						<h3 class="mt-4 text-2xl font-bold tracking-tight text-black dark:text-white">
							{project.title}
						</h3>
						<p class="mt-4 text-sm leading-7 text-gray-700 dark:text-gray-300">
							{project.description}
						</p>
						<p class="mt-5 text-sm font-medium text-gray-500 dark:text-gray-400">
							{project.stack}
						</p>
						<a
							href={project.link}
							target="_blank"
							class="absolute bottom-6 right-6 text-sm font-semibold text-black transition hover:scale-110 dark:text-white"
						>
							<svg
								viewBox="0 0 24 24"
								width="24"
								height="24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-external-link-icon lucide-external-link"
							>
								<>
									<path d="M15 3h6v6" />
									<path d="M10 14 21 3" />
									<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
								</>
							</svg>
						</a>
					</article>
				))
			}
		</div>
	</section>

	<section
		class="grid gap-8 border-y border-black/10 py-10 lg:grid-cols-[0.9fr_1.1fr] dark:border-white/10"
	>
		<div>
			<p
				class="text-sm font-semibold uppercase tracking-[0.3em] text-gray-500 dark:text-gray-400"
			>
				Experience
			</p>
			<h2
				class="mt-2 text-3xl font-black tracking-tight text-black dark:text-white sm:text-4xl"
			>
				Recent work.
			</h2>
		</div>

		<div class="space-y-4">
			{
				experience.map((item) => (
					<div class="rounded-3xl border-2 border-black/10 bg-black/2 p-5 dark:border-white/10 dark:bg-white/5">
						<div class="flex flex-wrap items-center justify-between gap-2">
							<h3 class="text-lg font-bold text-black dark:text-white">
								{item.role}
							</h3>
							<p class="text-sm text-gray-500 dark:text-gray-400">
								{item.period}
							</p>
						</div>
						<p class="mt-3 text-sm leading-7 text-gray-700 dark:text-gray-300">
							{item.description}
						</p>
						<p class="mt-5 text-sm font-medium text-gray-500 dark:text-gray-400">
							{item.stack}
						</p>
					</div>
				))
			}
		</div>
	</section>
</Layout>
